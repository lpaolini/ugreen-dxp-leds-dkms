#!/bin/sh
set -eu

MODULE_NAME="led-ugreen"
I2C_ADDR="0x3a"
I2C_ADDR_DIR="003a"

modprobe i2c-dev || true
modprobe "$MODULE_NAME"

for adapter in /sys/class/i2c-adapter/i2c-*; do
    [ -d "$adapter" ] || continue

    name="$(cat "$adapter/name")"
    case "$name" in
        *"SMBus I801 adapter"*)
            bus="${adapter##*-}"
            device="/sys/bus/i2c/devices/${bus}-${I2C_ADDR_DIR}"

            if [ -e "$device" ]; then
                exit 0
            fi

            if printf '%s %s\n' "$MODULE_NAME" "$I2C_ADDR" > "$adapter/new_device"; then
                exit 0
            fi
            ;;
    esac
done

echo "No SMBus I801 adapter found for ${MODULE_NAME} at ${I2C_ADDR}" >&2
exit 1
